{
  "expo": {
    "name": "Çekirdek Chat",
    "slug": "cekirdek-chat-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.cekirdek.chat",
      "permissions": [
        "INTERNET",
        "RECORD_AUDIO",
        "CAMERA",
        "ACCESS_NETWORK_STATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      }
    }
  }
}
