{
  "name": "cekirdek-chat",
  "version": "0.1.0",
  "description": "Çekirdek Chat - Peer-to-Peer Chat Application",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd frontend && npm install && cd ../backend-python && pip install -r requirements.txt",
    "postinstall": "cd frontend && npm install",
    "dev:frontend": "cd frontend && npm start",
    "build": "cd frontend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "dev:backend": "cd backend-python && python server.py",
    "electron:build": "npm run build && electron-builder --windows --publish never",
    "electron:start": "npm run build && electron ."
  },
  "build": {
    "appId": "com.cekirdek.chat",
    "productName": "Çekirdek Chat",
    "files": [
      "frontend/dist/**/*",
      "electron-main.js",
      "electron-preload.js",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": ["nsis"],
      "publish": null
    }
  },
  "dependencies": {
    "electron": "^26.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.6.0"
  },
  "keywords": ["p2p", "chat", "peer", "websocket"]
}
